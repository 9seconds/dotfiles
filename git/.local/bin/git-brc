#!/usr/bin/env fish
# vim: set ts=2 sts=2 sw=2:

set this_script_path $(path resolve $(status --current-filename))
set this_script_name $(path basename $this_script_path)

function show_help
  echo "Usage: $this_script_name [-h/--help] [-d/--debug]"
  echo
  echo 'Cleanup gone branches.'
  echo
  echo '  -h / --help    show this help'
  echo '  -d / --debug   run in debug mode'
end

argparse --max-args=0 'h/help&' 'd/debug&' -- $argv
or begin
  show_help
  return 1
end

if set -q _flag_debug
  set fish_trace 1
end
if set -q _flag_help
  show_help
  return 0
end

set    fzf_flags -m
set -a fzf_flags --accept-nth=1
set -a fzf_flags '--prompt=branch> '
set -a fzf_flags --preview='git l --color=always -n 30 {}'

set branches $(git br list -a -u gone -- name target ago | 9fzf $fzf_flags)
if test (count $branches) -gt 0
  exec git branch -D $branches
end
