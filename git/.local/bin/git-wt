#!/usr/bin/env python3

from __future__ import annotations

import argparse
import logging
import os
import pathlib
import typing as t

from nineseconds import cache
from nineseconds import cli
from nineseconds import env
from nineseconds import git
from nineseconds import paths
from nineseconds import strings
from nineseconds import symlinks


LOG: t.Final = logging.getLogger(__name__)
TEMPLATES_DIR: t.Final = paths.config("git-wt")
CACHE: t.Final = cache.Cache("git-wt")
MAIN_PROJECT: t.Final = "MAIN"


class Worktrees:
    _paths: dict[str, pathlib.Path]
    _heads: dict[str, str]
    _branches: dict[str, str]

    def __init__(self) -> None:
        self._paths = {}
        self._heads = {}
        self._branches = {}

    def __contains__(self, key: str) -> bool:
        return key in self._paths

    def names(self) -> list[str]:
        return sorted(self._paths)

    def path(self, key: str) -> pathlib.Path:
        return self._paths[key]

    def head(self, key: str) -> str:
        return self._heads[key]

    def branch(self, key: str) -> str | None:
        return self._branches.get(key, None)

    @classmethod
    def scan(cls, name: str, storage: pathlib.Path) -> Worktrees:
        inst = cls()

        for line in git.run("worktree", "list", "--porcelain"):
            match line.split():
                case ["worktree", value]:
                    path = pathlib.Path(value)
                    if not path.is_relative_to(storage):
                        continue

                    if path.name == name:
                        project = MAIN_PROJECT
                    elif path.name.startswith(f"{name}-"):
                        project = path.name[len(name) + 1 :]
                    else:
                        continue

                    inst._paths[project] = path
                case ["HEAD", value]:
                    inst._heads[project] = value
                case ["branch", value]:
                    inst._branches[project] = value.removeprefix("refs/heads/")

        return inst


@cli.main
def main() -> argparse.ArgumentParser:
    def get_project() -> str:
        if git.is_inside_git_worktree(cwd=pathlib.Path.cwd()):
            return git.get_common_dir().parent.name
        return ""

    def get_storage() -> str:
        if git.is_inside_git_worktree(cwd=pathlib.Path.cwd()):
            return str(git.get_common_dir().parent.parent)
        return ""

    parser = argparse.ArgumentParser(
        description="9seconds manages git worktrees.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )

    parser.add_argument(
        "-p",
        "--project-name",
        **cli.env_argument(
            "project name",
            f"{env.PREFIX}_GIT_WT_PROJECT",
            get_project,
        ),
    )
    parser.add_argument(
        "-s",
        "--storage",
        type=cli.type_valid_dir,
        **cli.env_argument(
            "directory where projects are stored",
            f"{env.PREFIX}_GIT_WT_STORAGE",
            get_storage,
        ),
    )

    commands = parser.add_subparsers(title="Commands")

    add_cmd = commands.add_parser(
        "add",
        aliases=["a"],
        description="Add a new worktree based on a template.",
        help="add new worktree",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    add_cmd.add_argument("name", help="name of the worktree")
    add_cmd.set_defaults(cmd=cmd_add)

    list_cmd = commands.add_parser(
        "list",
        aliases=["ls"],
        description="List known worktrees",
        help="list worktrees.",
    )
    list_cmd.set_defaults(cmd=cmd_list)

    remove_cmd = commands.add_parser(
        "remove",
        aliases=["r", "rm"],
        description="Remove a worktree.",
        help="remove worktrees.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    remove_cmd.add_argument(
        "name",
        nargs=argparse.ONE_OR_MORE,
        help="names (or paths) to worktrees to remove",
    )
    remove_cmd.set_defaults(cmd=cmd_remove)

    provision_cmd = commands.add_parser(
        "populate",
        aliases=["p"],
        description="Repopulate symlinks.",
        help="repopulate symlinks.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    provision_cmd.set_defaults(cmd=cmd_populate)

    for cmd_ in add_cmd, provision_cmd:
        cmd_.add_argument(
            "-t",
            "--template-dir",
            type=cli.type_valid_dir,
            default=TEMPLATES_DIR,
            help="path to directory with templates",
        )

    return parser


def cmd_add(options: argparse.Namespace) -> None:
    if options.name == MAIN_PROJECT:
        raise ValueError("Cannot add a main project")

    worktrees = Worktrees.scan(options.project_name, options.storage)
    if options.name in worktrees:
        raise ValueError("Such worktree already exists")

    options.template_dir.mkdir(exist_ok=True, parents=True)

    source_dir = options.template_dir / options.project_name
    source_dir.parent.mkdir(exist_ok=True, parents=True)

    target_dir = options.storage / f"{options.project_name}-{options.name}"
    git.run("worktree", "add", "--detach", target_dir)

    symlinks.mount(source_dir, target_dir, cache_=CACHE)


def cmd_list(options: argparse.Namespace) -> None:
    worktrees = Worktrees.scan(options.project_name, options.storage)

    rows = [
        [
            name,
            os.fspath(worktrees.path(name)),
            worktrees.head(name),
            worktrees.branch(name) or "",
        ]
        for name in worktrees.names()
    ]
    strings.print_rows(rows)


def cmd_remove(options: argparse.Namespace) -> None:
    worktrees = Worktrees.scan(options.project_name, options.storage)

    for name in options.name:
        if name == MAIN_PROJECT:
            raise ValueError("Cannot delete main project")
        if name not in worktrees:
            raise ValueError(f"Unknown name {name}")

    source_dir = options.template_dir / options.project_name

    for name in options.name:
        target_dir = worktrees.path(name)
        git.run("worktree", "remove", "--force", worktrees.path(name))
        CACHE.pop(symlinks.cache_key(source_dir, target_dir), None)


def cmd_populate(options: argparse.Namespace) -> None:
    source_dir = options.template_dir / options.project_name
    target_dir = pathlib.Path(
        git.run("rev-parse", "--show-toplevel")[0]
    ).absolute()

    symlinks.unmount(source_dir, target_dir, cache_=CACHE)
    symlinks.mount(source_dir, target_dir, cache_=CACHE)


if __name__ == "__main__":
    main()
