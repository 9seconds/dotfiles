#!/usr/bin/env python3

# ruff: noqa: PTH118

from __future__ import annotations

import argparse
import dataclasses
import functools
import logging
import os
import os.path
import pathlib
import shutil
import subprocess
import sys
import typing as t

if t.TYPE_CHECKING:
    import collections.abc


LOG: t.Final = logging.getLogger()
PATH_XDG_CONFIG_DIR: t.Final = pathlib.Path(
    os.getenv("XDG_CONFIG_DIR", pathlib.Path.home() / ".config")
)
MAIN_PROJECT: t.Final = "MAIN"


class LogFormatter(logging.Formatter):
    DEBUG: t.ClassVar = logging.Formatter(">>> %(message)s")
    MAIN: t.ClassVar = logging.Formatter(">   %(message)s")
    WARN: t.ClassVar = logging.Formatter("!   %(message)s")
    ALERT: t.ClassVar = logging.Formatter("!!! %(message)s")

    def format(self, record: logging.LogRecord) -> str:
        match record.levelno:
            case logging.DEBUG:
                return self.DEBUG.format(record)
            case logging.INFO:
                return self.MAIN.format(record)
            case logging.WARNING:
                return self.WARN.format(record)
        return self.ALERT.format(record)


@dataclasses.dataclass(frozen=True, kw_only=True)
class SubcommandError(Exception):
    stderr: list[str] = dataclasses.field(default_factory=list)
    exit_code: int = dataclasses.field(default=1)


class Worktrees:
    _paths: dict[str, pathlib.Path]
    _heads: dict[str, str]
    _branches: dict[str, str]

    def __init__(self) -> None:
        self._paths = {}
        self._heads = {}
        self._branches = {}

    def __contains__(self, key: str) -> bool:
        return key in self._paths

    def names(self) -> list[str]:
        return sorted(self._paths)

    def path(self, key: str) -> pathlib.Path:
        return self._paths[key]

    def head(self, key: str) -> str:
        return self._heads[key]

    def branch(self, key: str) -> str | None:
        return self._branches.get(key, None)

    @classmethod
    def scan(cls, name: str, storage: pathlib.Path) -> Worktrees:
        inst = cls()

        for line in git_exec("worktree", "list", "--porcelain"):
            match line.split():
                case ["worktree", value]:
                    path = pathlib.Path(value)
                    if not path.is_relative_to(storage):
                        continue

                    if path.name == name:
                        project = MAIN_PROJECT
                    elif path.name.startswith(f"{name}-"):
                        project = path.name[len(name) + 1 :]
                    else:
                        continue

                    inst._paths[project] = path
                case ["HEAD", value]:
                    inst._heads[project] = value
                case ["branch", value]:
                    inst._branches[project] = value.removeprefix("refs/heads/")

        return inst


def main() -> None:
    options = get_options()

    log_handler = logging.StreamHandler()
    log_handler.setFormatter(LogFormatter())
    LOG.addHandler(log_handler)
    LOG.setLevel(logging.DEBUG if options.debug else logging.ERROR)

    LOG.info("Options: %s", options)
    LOG.info("Git binary: %s", git_bin())
    LOG.info("Git directory: %s", git_dir())
    LOG.info("Git common directory: %s", git_common_dir())

    try:
        options.cmd(options)
    except SubcommandError as exc:
        for line in exc.stderr:
            print(line, file=sys.stderr)  # noqa: T201
        sys.exit(exc.exit_code)
    except Exception as exc:
        sys.exit(str(exc))


def get_options() -> argparse.Namespace:
    def type_dir(value: str) -> pathlib.Path:
        path = pathlib.Path(value)
        if not path.is_dir():
            raise argparse.ArgumentTypeError("not a directory")
        return path

    parser = argparse.ArgumentParser(
        description="9seconds manages git worktrees.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )

    parser.add_argument(
        "-d",
        "--debug",
        action="store_true",
        default=False,
        help="run in debug mode",
    )
    parser.add_argument(
        "-p",
        "--project-name",
        default=os.getenv("GIT_WT_PROJECT", git_common_dir().parent.name),
        help="project name",
    )
    parser.add_argument(
        "-s",
        "--storage",
        type=type_dir,
        default=os.getenv("GIT_WT_STORAGE", git_common_dir().parent.parent),
        help="directory where projects are stored",
    )
    parser.set_defaults(cmd=lambda _: parser.print_help())

    commands = parser.add_subparsers(title="Commands")

    add_cmd = commands.add_parser(
        "add",
        aliases=["a"],
        description="Add a new worktree based on a template.",
        help="add new worktree",
    )
    add_cmd.add_argument(
        "-t",
        "--template-dir",
        type=type_dir,
        default=os.getenv(
            "XDG_CONFIG_DIR",
            pathlib.Path.home() / ".config" / "9seconds" / "git-wt",
        ),
        help="path to directory with templates",
    )
    add_cmd.add_argument("name", help="name of the worktree")
    add_cmd.set_defaults(cmd=cmd_add)

    list_cmd = commands.add_parser(
        "list",
        aliases=["ls"],
        description="List known worktrees",
        help="list worktrees.",
    )
    list_cmd.set_defaults(cmd=cmd_list)

    remove_cmd = commands.add_parser(
        "remove",
        aliases=["r", "rm"],
        description="Remove a worktree.",
        help="remove worktrees.",
    )
    remove_cmd.add_argument(
        "name",
        nargs=argparse.ONE_OR_MORE,
        help="names (or paths) to worktrees to remove",
    )
    remove_cmd.set_defaults(cmd=cmd_remove)

    return parser.parse_args()


def cmd_add(options: argparse.Namespace) -> None:
    if options.name == MAIN_PROJECT:
        raise ValueError("Cannot add a main project")

    worktrees = Worktrees.scan(options.project_name, options.storage)
    if options.name in worktrees:
        raise ValueError("Such worktree already exists")

    options.template_dir.mkdir(exist_ok=True, parents=True)

    template_dir = t.cast(
        "pathlib.Path", options.template_dir / options.project_name
    )
    if not template_dir.is_dir():
        raise ValueError(f"Template dir {template_dir} does not exist")

    template_hook = template_dir.with_suffix(".bash")
    if not template_hook.exists():
        raise ValueError(f"Script {template_hook} does not exist")
    if not os.access(template_hook, os.R_OK | os.X_OK):
        raise ValueError(f"Script {template_hook} cannot be executed")

    wt_dir = options.storage / f"{options.project_name}-{options.name}"
    git_exec("worktree", "add", "--detach", wt_dir)

    for dirname, _, filenames in os.walk(template_dir):
        dirpath = pathlib.Path(dirname)
        for filename in filenames:
            filepath = dirpath / filename
            wt_path = wt_dir / filepath.relative_to(template_dir)
            wt_path.parent.mkdir(exist_ok=True, parents=True)
            wt_path.symlink_to(filepath)
            LOG.info("Symlinked %s to %s", wt_path, filepath)

    cmd_exec(
        "bash",
        template_hook,
        cwd=wt_dir,
        env={"SHELLOPTS": "errexit:nounset:pipefail"},
    )


def cmd_list(options: argparse.Namespace) -> None:
    worktrees = Worktrees.scan(options.project_name, options.storage)

    rows = [
        [
            name,
            os.fspath(worktrees.path(name)),
            worktrees.head(name),
            worktrees.branch(name) or "",
        ]
        for name in worktrees.names()
    ]
    print_rows(rows)


def cmd_remove(options: argparse.Namespace) -> None:
    worktrees = Worktrees.scan(options.project_name, options.storage)

    for name in options.name:
        if name == MAIN_PROJECT:
            raise ValueError("Cannot delete main project")
        if name not in worktrees:
            raise ValueError(f"Unknown name {name}")

    for name in options.name:
        git_exec("worktree", "remove", "--force", worktrees.path(name))


def print_rows(rows: collections.abc.Sequence[list[str]]) -> None:
    lengths = [0] * len(rows[0])

    for row in rows:
        for idx, col in enumerate(row):
            lengths[idx] = max(len(col), lengths[idx])

    for row in rows:
        values = (
            col.rjust(length) for length, col in zip(lengths, row, strict=True)
        )
        print("\t".join(values))  # noqa: T201


@functools.lru_cache(maxsize=1)
def git_bin() -> pathlib.Path:
    if value := os.getenv("GIT_EXEC_PATH"):
        path = os.path.join(value, "git")
    else:
        path = shutil.which("git") or ""

    if shutil.which(path) is None:
        raise OSError(f"Cannot detect git binary: {path}")

    return pathlib.Path(path).absolute()


@functools.lru_cache(maxsize=1)
def git_dir() -> pathlib.Path:
    if value := os.getenv("GIT_DIR"):
        path = value
    else:
        path = git_exec("rev-parse", "--absolute-git-dir", set_git_dir=False)[0]

    return pathlib.Path(path).absolute()


@functools.lru_cache(maxsize=1)
def git_common_dir() -> pathlib.Path:
    path = git_exec("rev-parse", "--git-common-dir")[0]
    return pathlib.Path(path).absolute()


def git_exec(*cmd: str | pathlib.Path, set_git_dir: bool = True) -> list[str]:
    git_dir_cmd: list[str | pathlib.Path] = []
    if set_git_dir:
        git_dir_cmd = ["--git-dir", git_dir()]

    return cmd_exec(
        git_bin(),
        "-P",  # no pager
        "--no-advice",
        *git_dir_cmd,
        *cmd,
        env={"NO_COLOR": "1"},
    )


def cmd_exec(
    *cmd: str | pathlib.Path,
    cwd: None | pathlib.Path = None,
    env: dict[str, str] | None = None,
) -> list[str]:
    LOG.debug("Execute %s", subprocess.list2cmdline(cmd))

    result = subprocess.run(  # noqa: S603
        [str(el) for el in cmd],
        stdin=subprocess.DEVNULL,
        check=False,
        capture_output=True,
        text=True,
        cwd=cwd or pathlib.Path.cwd(),
        env={**os.environ, **(env or {})},
    )
    stdout = result.stdout.splitlines()
    stderr = result.stderr.splitlines()

    LOG.debug("  Exit code: %d", result.returncode)
    for line in stdout:
        LOG.debug("  Stdout: %s", line)
    for line in stderr:
        LOG.debug("  Stderr: %s", line)

    if result.returncode:
        raise SubcommandError(exit_code=result.returncode, stderr=stderr)

    return stdout


if __name__ == "__main__":
    main()
