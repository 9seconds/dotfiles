from __future__ import annotations

import argparse
import concurrent.futures
import datetime
import functools
import logging
import re
import sys
import typing as t

from nineseconds import cli
from nineseconds import env
from nineseconds import exceptions
from nineseconds import git
from nineseconds import strings


LOG: t.Final = logging.getLogger(__name__)
POOL: t.Final = concurrent.futures.ThreadPoolExecutor()
NOW: t.Final = datetime.datetime.now(datetime.timezone.utc)


@cli.main
def main() -> argparse.ArgumentParser:
    def type_existing_branch(value: str) -> str:
        try:
            git.run("rev-parse", "--verify", value)
        except exceptions.CommandError as exc:
            raise argparse.ArgumentTypeError("branch does not exist") from exc
        return value

    def type_existing_remote_branch(value: str) -> str:
        if "/" not in value:
            raise argparse.ArgumentTypeError("ambiguous origin")
        return type_existing_branch(value)

    def type_existing_local_branch(value: str) -> str:
        if "/" in value:
            raise argparse.ArgumentTypeError("not a local branch")
        return type_existing_branch(value)

    parser = argparse.ArgumentParser(
        description="9seconds manages git branches.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )

    parser.add_argument(
        "-p",
        "--prefix",
        type=strings.slugify,
        **cli.env_argument(
            "branch prefix",
            f"{env.PREFIX}_GIT_BR_PREFIX",
            lambda: git.config_get("user.name"),
        )
    )

    commands = parser.add_subparsers(title="Commands")

    new_cmd = commands.add_parser(
        "new",
        aliases=["n"],
        description="Create new branch.",
        help="create branch",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    new_cmd.set_defaults(cmd=cmd_new)
    new_cmd.add_argument("-u", "--issue-url", help="URL to the issue")
    new_cmd.add_argument(
        "-U",
        "--regex-issue-url",
        type=lambda val: re.compile(val, re.UNICODE),
        **cli.env_argument(
            "regular expression used to extract issue number from URL",
            f"{env.PREFIX}_GIT_BR_ISSUE_URL_RE",
            lambda: None,
        )
    )
    new_cmd.add_argument(
        "stem",
        type=strings.slugify,
        help="Stem of the branch"
    )
    new_cmd.add_argument(
        "target",
        nargs=argparse.OPTIONAL,
        type=type_existing_remote_branch,
        default="origin/master",
        help="branch that is used as a target for this one",
    )

    set_cmd = commands.add_parser(
        "set",
        aliases=["s"],
        description="Set parameters for branches",
        help="set parameters for branches",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    set_cmd.set_defaults(cmd=cmd_set)
    set_cmd.add_argument(
        "parameter",
        choices=["pr", "issue", "target", "upstream"],
        help="parameter to set",
    )
    set_cmd.add_argument("value", help="value to set")
    set_cmd.add_argument(
        "branch",
        nargs=argparse.OPTIONAL,
        type=type_existing_local_branch,
        default=git.get_current_branch(),
        help="Branch to set to",
    )

    list_cmd = commands.add_parser(
        "list",
        aliases=["l", "ls"],
        description="List branches.",
        help="list branches",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    list_cmd.set_defaults(cmd=cmd_list)
    list_cmd.add_argument(
        "-a",
        "--all",
        action="count",
        default=0,
        help=(
            "show all branches, not only prefixed. "
            "2+ times to also show remotes"
        ),
    )
    list_cmd.add_argument(
        "-c",
        "--skip-current",
        action="store_true",
        default=False,
        help="skip current branch",
    )
    list_cmd.add_argument(
        "-u",
        "--upstream-state",
        choices=["gone", "ahead", "behind"],
        help="show only branches with that upstream state",
    )
    list_cmd.add_argument("-t", "--target", help="target to filter by")
    list_cmd.add_argument(
        "-o",
        "--older-than-days",
        type=cli.type_non_negative_int,
        help="show branches that are older than this number of days",
    )
    list_cmd.add_argument(
        "-s",
        "--sort",
        nargs=argparse.ZERO_OR_MORE,
        choices=list(Branch.SORT_FIELDS)
        + [f"_{name}" for name in Branch.SORT_FIELDS],
        default=["name"],
        help="sort branches",
    )
    list_cmd.add_argument(
        "field",
        nargs=argparse.ZERO_OR_MORE,
        choices=Branch.FIELDS,
        default="name",
        help="fields to show",
    )

    info_cmd = commands.add_parser(
        "info",
        aliases=["i"],
        description="Information about a local branch.",
        help="information about a local branch",
    )
    info_cmd.set_defaults(cmd=cmd_info)
    info_cmd.add_argument(
        "branch",
        nargs=argparse.OPTIONAL,
        type=type_existing_local_branch,
        default=git.get_current_branch(),
        help="branch to show information about",
    )

    return parser


class Branch:
    name: str
    abbrev_head: str
    head: str
    subject: str
    upstream: str
    _timestamp: datetime.datetime
    _upstream_state: str

    FIELDS: t.ClassVar = (
        "abbrev_head",
        "ago",
        "commits",
        "head",
        "issue",
        "name",
        "pr",
        "subject",
        "target",
        "target_branch",
        "target_repo",
        "timestamp",
        "upstream",
        "upstream_branch",
        "upstream_repo",
        "upstream_state",
    )
    SORT_FIELDS: t.ClassVar = (
        "name",
        "target",
        "target_branch",
        "target_repo",
        "upstream",
        "upstream_branch",
        "upstream_repo",
        "age",
    )

    def __init__(  # noqa: PLR0913
        self,
        *,
        name: str,
        abbrev_head: str,
        head: str,
        date: str,
        subject: str,
        upstream: str,
        upstream_state: str,
    ) -> None:
        self.name = name
        self.abbrev_head = abbrev_head
        self.head = head
        self.subject = subject
        self.upstream = upstream
        self._timestamp = datetime.datetime.fromisoformat(
            date.replace("Z", "+00:00")
        )
        self._upstream_state = upstream_state

    @classmethod
    def get_remote_repo(cls, value: str) -> str:
        try:
            repo, _ = value.split("/", maxsplit=1)
        except ValueError:
            return ""
        return repo

    @classmethod
    def get_remote_branch(cls, value: str) -> str:
        try:
            _, branch = value.split("/", maxsplit=1)
        except ValueError:
            return ""
        return branch

    @functools.cache  # noqa: B019
    def _get_git_config(self, value: str) -> str:
        return git.config_get(f"branch.{self.name}.{value}")

    @functools.cached_property
    def age(self) -> int | float:
        return (NOW - self._timestamp).total_seconds()

    @functools.cached_property
    def timestamp(self) -> str:
        return self._timestamp.isoformat()

    @property
    def ago(self) -> str:  # noqa: PLR0911
        today = NOW - self._timestamp
        seconds = today.total_seconds()

        if seconds < 60:  # noqa: PLR2004
            return "now"
        if seconds < 120:  # noqa: PLR2004
            return f"{int(seconds / 60)}min"
        if seconds < 120 * 4:
            return f"{int(seconds / 120)}h"

        days = (NOW.date() - self._timestamp.date()).days

        if days == 0:
            return "today"
        if days == 1:
            return "yesterday"
        if days < 7:  # noqa: PLR2004
            return f"{days}d"
        if days < 31:  # noqa: PLR2004
            return f"{int(days / 7)}w"
        if days < 365:  # noqa: PLR2004
            return f"{int(days / 31)}m"
        return f"{int(days / 365)}y"

    @property
    def branch_name(self) -> str:
        return self.get_remote_branch(self.name) or self.name

    @property
    def upstream_repo(self) -> str:
        return self.get_remote_repo(self.upstream)

    @property
    def upstream_branch(self) -> str:
        return self.get_remote_branch(self.upstream)

    @property
    def target(self) -> str:
        return self._get_git_config("target")

    @property
    def pr(self) -> str:
        return self._get_git_config("pr")

    @property
    def issue(self) -> str:
        return self._get_git_config("issue")

    @property
    def target_repo(self) -> str:
        return self.get_remote_repo(self.target)

    @property
    def target_branch(self) -> str:
        return self.get_remote_branch(self.target)

    @property
    def gone(self) -> bool:
        return "g" in self._upstream_state

    @property
    def behind(self) -> bool:
        return "b" in self._upstream_state

    @property
    def ahead(self) -> bool:
        return "a" in self._upstream_state

    @property
    def upstream_state(self) -> str:
        match self:
            case Branch(gone=True):
                return "⌀"
            case Branch(ahead=True, behind=True):
                return "⇅"
            case Branch(ahead=True):
                return "↑"
            case Branch(behind=True):
                return "↓"
            case _:
                return "✔"

    @functools.cached_property
    def commits(self) -> int:
        if "/" in self.name or not self.target:
            return 0

        return int(
            git.run("rev-list", "--count", f"{self.target}..{self.name}")[0]
        )


class BranchMatcher:
    matchers: list[t.Callable[[Branch], bool]]

    def __init__(self) -> None:
        self.matchers = []

    def __call__(self, branch: Branch) -> bool:
        LOG.debug("Matching %s", branch.name)
        return all(m(branch) for m in self.matchers)

    def match_upstream_state(self, state: str) -> None:
        def match(branch: Branch) -> bool:
            result = getattr(branch, state)
            LOG.debug(
                "  match_upstream_state: upstream_state=%s, result=%s",
                state,
                result,
            )
            return result

        self.matchers.append(match)

    def match_target(self, target: str) -> None:
        def match(branch: Branch) -> bool:
            result = branch.target == target
            LOG.debug("  match_target: target=%s, result=%s", target, result)
            return result

        self.matchers.append(match)

    def match_older_than_days(self, days: int) -> None:
        def match(branch: Branch) -> bool:
            age_in_days = round(branch.age / (60 * 60 * 24))
            result = age_in_days >= days
            LOG.debug(
                "  match_older_than_days: age=%s, age_in_days=%s, result=%s",
                branch.age,
                age_in_days,
                result,
            )
            return result

        self.matchers.append(match)

    def match_prefix(self, prefix: str) -> None:
        prefix = prefix.removesuffix("-") + "-"

        def match(branch: Branch) -> bool:
            LOG.debug(
                "  match_prefix: branch_name=%s prefix=%s",
                branch.branch_name,
                prefix,
            )
            return branch.branch_name.startswith(prefix)

        self.matchers.append(match)

    def skip_current(self) -> None:
        current = git.get_current_branch()

        def match(branch: Branch) -> bool:
            result = branch.branch_name != current
            LOG.debug(
                "  skip_current: branch=%s, current=%s",
                branch.branch_name,
                current,
            )
            return result

        self.matchers.append(match)


def make_branch_sorted(fields: list[str]) -> t.Callable[[Branch], tuple]:
    def make_tuple(field_name: str, reversed_: bool, branch: Branch) -> tuple:  # noqa: FBT001
        value = getattr(branch, field_name)
        if not reversed_:
            return value

        match value:
            case str():
                return tuple(sys.maxsize - ord(c) for c in value)
            case int() | float():
                return (-value,)
            case bool():
                return (not value,)
            case _:
                raise TypeError(f"unexpected type {value} of {field_name}")

    tuple_makers = []
    for field in fields:
        reversed_ = field.startswith("_")
        if reversed_:
            field = field[1:]  # noqa: PLW2901
        tuple_makers.append(functools.partial(make_tuple, field, reversed_))

    def keyfunc(branch: Branch) -> tuple:
        sort_tup = tuple(maker(branch) for maker in tuple_makers)
        LOG.debug("Sort key for %s: %r", branch.name, sort_tup)
        return sort_tup

    return keyfunc


def cmd_new(options: argparse.Namespace) -> None:
    branch_chunks = [options.prefix]

    if options.regex_issue_url and options.issue_url:
        matched = options.regex_issue_url.search(options.issue_url)
        if matched is None:
            raise ValueError("Cannot extract issue from URL")
        branch_chunks.append(strings.slugify("".join(matched.groups())))

    branch_chunks.append(options.stem)
    branch_name = "-".join(branch_chunks)

    git.run("switch", "--no-track", "--no-guess", "-c", branch_name)
    LOG.info("Branch %s is created", branch_name)

    remote = Branch.get_remote_repo(options.target)
    git.config_set(f"branch.{branch_name}.remote", remote)
    git.config_set(f"branch.{branch_name}.merge", f"refs/heads/{branch_name}")
    LOG.info("Set remote to %s", remote)

    git.config_set(f"branch.{branch_name}.target", options.target)
    LOG.info("Set target to %s", options.target)

    git.config_set(f"branch.{branch_name}.issue", options.issue_url or "")
    LOG.info("Set issue_url to %s", options.issue_url or "")

    git.config_set(f"branch.{branch_name}.pr", "")
    LOG.info("Set empty PR")


def cmd_set(options: argparse.Namespace) -> None:
    if options.parameter == "upstream":
        git.config_set(
            f"branch.{options.branch}.remote",
            Branch.get_remote_repo(options.value),
        )
        git.config_set(
            f"branch.{options.branch}.merge",
            f"refs/heads/{Branch.get_remote_branch(options.value)}",
        )
        return

    git.config_set(
        f"branch.{options.branch}.{options.parameter}",
        options.value,
    )


def cmd_list(options: argparse.Namespace) -> None:
    matcher = BranchMatcher()

    if options.all == 0:
        matcher.match_prefix(options.prefix)
    if options.skip_current:
        matcher.skip_current()
    if options.target is not None:
        matcher.match_target(options.target)
    if options.upstream_state is not None:
        matcher.match_upstream_state(options.upstream_state)
    if options.older_than_days is not None:
        matcher.match_older_than_days(options.older_than_days)

    branches = [
        br for br in git_branches(with_remotes=options.all > 1) if matcher(br)
    ]
    branches.sort(key=make_branch_sorted(options.sort))

    if isinstance(options.field, str):
        fields_to_show = [options.field]
    else:
        fields_to_show = options.field

    if "commits" in fields_to_show:
        for fut in [POOL.submit(getattr, br, "commits") for br in branches]:
            fut.result()

    strings.print_rows(
        [
            [str(getattr(br, field)) for field in fields_to_show]
            for br in branches
        ],
        is_shlex=options.shlex,
    )


def cmd_info(options: argparse.Namespace) -> None:
    branch = git_branches(branch=options.branch, with_remotes=False)[0]
    strings.print_rows(
        [
            ("Name", branch.name),
            ("Head", branch.head),
            ("Short Head", branch.abbrev_head),
            ("Subject", branch.subject),
            ("Age", branch.ago),
            ("Target", branch.target),
            ("Upstream", branch.upstream),
            ("Upstream State", branch.upstream_state),
            ("Commits", branch.commits),
            ("Issue URL", branch.issue),
            ("PR", branch.pr),
        ],
        is_shlex=options.shlex,
    )


@functools.lru_cache
def git_branches(*, branch: str = "", with_remotes: bool) -> list[Branch]:
    refs: list[str] = []

    if branch:
        refs.append(f"refs/heads/{branch}")
    else:
        refs.append("refs/heads")

    if with_remotes:
        if branch:
            refs.append(f"refs/remotes/*/{branch}")
        else:
            refs.append("refs/remotes")

    output = git.run(
        "for-each-ref",
        *refs,
        "--exclude=refs/remotes/*/HEAD",
        #         0                  1                   2                   3               4                     5                          6  # noqa: E501
        "--format=%(refname:short)%00%(upstream:short)%00%(upstream:track)%00%(objectname)%00%(objectname:short)%00%(authordate:iso-strict)%00%(subject)",
    )

    branches: list[Branch] = []
    for line in output:
        fields = line.split("\x00")
        branches.append(
            Branch(
                name=fields[0],
                upstream=fields[1],
                upstream_state=fields[2],
                head=fields[3],
                abbrev_head=fields[4],
                date=fields[5],
                subject=fields[6],
            )
        )

    return branches


if __name__ == "__main__":
    main()
