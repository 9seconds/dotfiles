{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 50000
  },

  "permission": {
    "read": "allow",
    "grep": "allow",
    "task": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "col *": "allow",
      "find *": "allow",
      "git blame *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge-base *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls": "allow",
      "man *": "allow",
      "python -m py_compile *": "allow",
      "rg *": "allow",
      "rtk col *": "allow",
      "rtk find *": "allow",
      "rtk git blame *": "allow",
      "rtk git diff *": "allow",
      "rtk git log *": "allow",
      "rtk git merge-base *": "allow",
      "rtk git show *": "allow",
      "rtk git status *": "allow",
      "rtk grep *": "allow",
      "rtk head *": "allow",
      "rtk ls": "allow",
      "rtk man *": "allow",
      "rtk rg *": "allow",
      "rtk systemctl cat *": "allow",
      "sort *": "allow",
      "systemctl cat *": "allow",
      "systemctl list-*": "allow",
      "systemctl show *": "allow",
      "uniq *": "allow",
      "wc *": "allow"
    }
  },

  "lsp": {
    "pyright": {
      "disabled": true
    }
  }
}
