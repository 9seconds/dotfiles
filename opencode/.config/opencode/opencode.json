{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 50000
  },

  "permission": {
    "read": "allow",
    "grep": "allow",
    "task": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "col *": "allow",
      "bash -n *": "allow",
      "find *": "allow",
      "git blame *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge-base *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls": "allow",
      "man *": "allow",
      "python -m py_compile *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "systemctl cat *": "allow",
      "systemctl list-*": "allow",
      "systemctl show *": "allow",
      "true *": "allow",
      "uniq *": "allow",
      "wc *": "allow"
    }
  },

  "mcp": {
    "cs": {
      "command": ["cs", "--find-root", "--mcp"],
      "type": "local",
      "enabled": true
    },

    "context7": {
      "command": ["context7-mcp"],
      "type": "local",
      "enabled": true
    }
  },

  "lsp": {
    "basedpyright": {
      "command": [
        "basedpyright-langserver",
        "--stdio"
      ],
      "extensions": [".py"],
      "initizalization": {
        "basedpyright": {
          "analysis": {
            "typeCheckingMode": "off"
          }
        }
      },
      "type": "local",
      "enabled": true
    },

    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"],
      "type": "local",
      "enabled": true
    },

    "pyright": {
      "disabled": true
    }
  }
}
