{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "permission": {
    "read": "allow",
    "grep": "allow",
    "task": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "find *": "allow",
      "git blame *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "wc *": "allow"
    }
  },

  "lsp": {
    "pyright": {
      "disabled": true
    }
  }
}
